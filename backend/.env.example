# Port and Host configuration for uvicorn (optional, defaults are 8000 and 127.0.0.1)
PORT=8000
HOST=127.0.0.1

# CORS allowed origins: comma-separated list of domains (must include the Next.js production frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLite database file path (can be relative to backend/ directory, or absolute)
PATHFINDER_DATABASE=../database/pathfinder.db

# PDF generation output directory (can be relative to backend/ directory, or absolute)
PATHFINDER_PDF_DIR=../pdfs
